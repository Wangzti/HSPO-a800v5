# ============================================================
# HSPO Secrets & API Keys
# ============================================================
# 复制为 .env 后填写实际值。.env 已在 .gitignore 中，不会提交。
#   cp .env.example .env
#   source .env
#
# ⚠️  路径配置已移至 config/paths.sh — 换服务器只需改那一个文件。
# ============================================================

# ── Wandb 配置 ──────────────────────────────────────────────
# 密钥：https://wandb.ai/authorize 获取（已登录用户）
# 或不设置此变量，提前运行 wandb login 写入 ~/.netrc
WANDB_API_KEY=

# Wandb entity（团队/用户名），可选
WANDB_ENTITY=

# Wandb 模式：online（默认）/ offline（无网络时）/ disabled（关闭）
WANDB_MODE=online

# ── HuggingFace 配置 ────────────────────────────────────────
# 离线模式下跳过 HF Hub 检查
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# HF 缓存目录（大模型下载位置），可选
# HF_HOME=/mnt/nfs/ztwang/models

# ── ALFWorld 配置 ───────────────────────────────────────────
# ALFWorld 数据目录
ALFWORLD_DATA=~/.cache/alfworld

# FastDownward 临时文件目录（避免 /tmp 满）
TMPDIR=/home/ztwang/tmp
